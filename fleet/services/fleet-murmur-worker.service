[Unit]
Description=Fleet Murmur Worker — MCP whisper router for inter-agent messaging
After=network.target
Wants=plato.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/.openclaw/workspace/repos/fleet-murmur-worker
ExecStart=/usr/bin/npx ts-node src/index.ts
Restart=always
RestartSec=10
StandardOutput=append:/tmp/fleet-murmur-worker.log
StandardError=append:/tmp/fleet-murmur-worker.log
Environment=PLATO_SERVER=http://localhost:8847

[Install]
WantedBy=multi-user.target
